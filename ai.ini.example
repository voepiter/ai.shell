# Example ai.ini — copy to ai.ini and adjust

[connection]
timeout = 30

[providers]
# default provider (google, openai, xai, deepseek, anthropic, openrouter)
default = "google"

[models]
# default model per provider — edit here when models change, no code changes needed
google     = "gemini-2.5-flash"
openai     = "gpt-4.1-mini"
xai        = "grok-3-mini"
deepseek   = "deepseek-chat"
anthropic  = "claude-sonnet-4-6"
openrouter = "meta-llama/llama-3.3-70b-instruct:free"

[assistant]
# default agent name (must be defined below)
default = "devops"

devops  = "IT expert: Linux, DevOps, Docker, Kubernetes. Short, practical answers."
coder   = "Expert programmer: Python, JavaScript, Go, Rust. Write clean, efficient code."
writer  = "Professional writer: Clear, engaging, well-structured text."
general = "Helpful assistant: Friendly, informative, concise answers."

[ui]
disable_logo = 0    # 1 = skip logo on startup
logo_delay   = 0.05 # seconds between lines (0 = instant)
gradient     = 0.08 # hue range across logo width
unicode      = true # false = replace ✨ ╭─╮ ▸ etc. with ASCII equivalents
